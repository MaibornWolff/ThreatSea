EXPRESS_SESSION_SECRET=someRandomExpressSessionSecret
JWT_SECRET=somerandomstringtobeusedasJWTsecret

ORIGIN_APP=<frontend url> # for local development it's http://localhost:3000
ORIGIN_BACKEND=<backend url> # for local development it's http://localhost:8000
LOG_LEVEL=<dev-default=0 (debug)| 1 (info) | 2 (warning) | prod-default=3 (error)>
# define where and how to connect to database; given values are for local development environment
DATABASE_HOST=127.0.0.1 # for local development
DATABASE_USER=threatsea # for local development
DATABASE_PASSWORD=threatseapassword # for local development
DATABASE_NAME=threatsea # for local development
DATABASE_TLS=<default=undefined|disabled> # don't use TLS for database connection; only use for tests or local setup
COOKIES_SECURE_OPTION=<default=undefined|disabled> # set to disabled for local testing
USE_PROXY=true # not needed for local environment, needed if COOKIES_SECURE_OPTION != disabled and app is behind a proxy

AUTH_METHOD=<default=oidc|fixed> # define authentication methody, use AUTH_METHOD=oidc for your OIDC authentication and AUTH_METHOD=fixed for local environment

OIDC_ISSUER_URL=<your-oidc-provider-issuer-url>
OIDC_CLIENT_ID=<your-oidc-provider-client-id>
OIDC_CLIENT_SECRET=<your-oidc-provider-client-secret>
OIDC_ALLOW_HTTP=<default=false|true> # Allow insecure HTTP connections to the OIDC provider. Only enable for local development if necessary.
OIDC_SCOPE=<default=openid profile email> # Space-separated OIDC scopes to request; must include "openid".
OIDC_ALLOW_UNVERIFIED_EMAIL_LINKING=<default=false|true> # Allow linking an OIDC login to an existing account when the IdP does not assert a verified email. Weakens account-takeover protection; only enable if you trust the IdP.

USER_PURGE_ENABLED=false # set to "true" to opt in to automatic hard-deletion of long-inactive users (disabled unless exactly "true")
USER_HIDE_THRESHOLD_DAYS=90 # days of inactivity before a user is hidden from member lists
USER_PURGE_THRESHOLD_DAYS=365 # days of inactivity before a user is hard-deleted (must be greater than USER_HIDE_THRESHOLD_DAYS)
USER_PURGE_INTERVAL_HOURS=24 # how often the purge job runs
